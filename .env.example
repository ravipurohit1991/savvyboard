# Copy this file to .env and update the values.
# Never commit the real .env file.

# Backend
SECRET_KEY=change-me-to-a-random-long-string-in-production
DATABASE_URI=sqlite:///./savvyboard.db
# DATABASE_URI=postgresql://postgres:postgres@db:5432/savvyboard
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
ENVIRONMENT=local

# First superuser created automatically on startup
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# PostgreSQL (used by docker-compose db service; ignored when using SQLite)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=savvyboard
